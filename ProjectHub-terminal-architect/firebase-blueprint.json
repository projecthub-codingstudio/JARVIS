{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The name to display for the user." },
        "email": { "type": "string", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The URL of the user's profile photo." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role in the system." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the profile was last updated." }
      },
      "required": ["uid", "email", "role"]
    },
    "SystemLog": {
      "title": "System Log",
      "description": "Stores system-wide logs for the admin dashboard.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["timestamp", "type", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "System-wide audit logs."
    }
  }
}
